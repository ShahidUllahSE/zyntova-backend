NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
API_BASE_PATH=/api

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/zyntova?retryWrites=true&w=majority&appName=ZYNTOVA

# Frontend (CORS)
CLIENT_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me-use-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Optional: seed first admin on startup (development)
ADMIN_EMAIL=admin@zyntova.ai
ADMIN_PASSWORD=admin123
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Password reset (link expires after 60 minutes by default)
PASSWORD_RESET_EXPIRES_MINUTES=60

# Optional SMTP — if unset, reset links are logged to the API console in development
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=hello@zyntova.ai
# SMTP_FROM_NAME=Zyntova AI
